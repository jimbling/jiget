<title><%= title %></title>

<body 
  class="min-h-screen bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 transition-colors duration-300"
  data-device-id="<%= device ? device.id : '' %>" 
  data-is-connected="<%= device ? device.isConnected : false %>"
>
  <div class="max-w-7xl mx-auto p-6">

    <!-- Header Section -->
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Dashboard Perangkat</h1>
        <p class="text-gray-600 dark:text-gray-400 mt-2">Kelola dan pantau perangkat WhatsApp Anda</p>
      </div>
      <div class="flex items-center gap-3 mt-4 lg:mt-0">
        <!-- Theme Toggle -->
        <button id="theme-toggle" class="p-2.5 bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 hover:shadow-md transition-all">
          <i class="fas fa-moon text-gray-600 dark:text-yellow-400"></i>
        </button>
        
        <!-- Refresh Button -->
        <button class="flex items-center gap-2 px-4 py-2.5 bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white rounded-xl shadow-sm hover:shadow-md transition-all">
          <i class="fas fa-sync-alt"></i>
          <span>Refresh</span>
        </button>
      </div>
    </div>

    <!-- Stats Overview -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <!-- Total Perangkat -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-6 border border-gray-100 dark:border-gray-700 hover:shadow-md transition-all duration-300">
        <div class="flex justify-between items-start">
          <div>
            <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Total Perangkat</p>
            <p class="text-3xl font-bold text-gray-900 dark:text-white mt-2"><%= stats.total %></p>
          </div>
          <div class="p-3 bg-green-50 dark:bg-green-900/20 rounded-xl">
            <i class="fas fa-mobile-alt text-xl text-green-600 dark:text-green-400"></i>
          </div>
        </div>
        <div class="flex items-center mt-4">
          <i class="fas fa-arrow-up text-green-500 text-sm mr-1"></i>
          <span class="text-sm text-green-600 dark:text-green-400 font-medium">Aktif</span>
        </div>
      </div>

      <!-- Terhubung -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-6 border border-gray-100 dark:border-gray-700 hover:shadow-md transition-all duration-300">
        <div class="flex justify-between items-start">
          <div>
            <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Terhubung</p>
            <p class="text-3xl font-bold text-gray-900 dark:text-white mt-2"><%= stats.connected %></p>
          </div>
          <div class="p-3 bg-blue-50 dark:bg-blue-900/20 rounded-xl">
            <i class="fas fa-link text-xl text-blue-600 dark:text-blue-400"></i>
          </div>
        </div>
        <div class="flex items-center mt-4">
          <span class="flex h-2 w-2 bg-green-500 rounded-full mr-2"></span>
          <span class="text-sm text-gray-600 dark:text-gray-400">Online</span>
        </div>
      </div>

      <!-- Status Akun -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-6 border border-gray-100 dark:border-gray-700 hover:shadow-md transition-all duration-300">
        <div class="flex justify-between items-start">
          <div>
            <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Status Akun</p>
            <p class="text-3xl font-bold text-gray-900 dark:text-white mt-2"><%= stats.users %></p>
          </div>
          <div class="p-3 bg-purple-50 dark:bg-purple-900/20 rounded-xl">
            <i class="fas fa-user-check text-xl text-purple-600 dark:text-purple-400"></i>
          </div>
        </div>
        <div class="flex items-center mt-4">
          <span class="text-sm text-gray-600 dark:text-gray-400">Pengguna aktif</span>
        </div>
      </div>

      <!-- Pesan Hari Ini -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-6 border border-gray-100 dark:border-gray-700 hover:shadow-md transition-all duration-300">
        <div class="flex justify-between items-start">
          <div>
            <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Pesan Hari Ini</p>
            <p class="text-3xl font-bold text-gray-900 dark:text-white mt-2">1.2K</p>
          </div>
          <div class="p-3 bg-orange-50 dark:bg-orange-900/20 rounded-xl">
            <i class="fas fa-comments text-xl text-orange-600 dark:text-orange-400"></i>
          </div>
        </div>
        <div class="flex items-center mt-4">
          <i class="fas fa-arrow-up text-green-500 text-sm mr-1"></i>
          <span class="text-sm text-green-600 dark:text-green-400 font-medium">+12%</span>
        </div>
      </div>
    </div>

    <% if (device) { %>
    <!-- Device Card -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg overflow-hidden transition-all duration-300 border border-gray-200 dark:border-gray-700">
      <!-- Card Header -->
      <div class="p-6 border-b border-gray-100 dark:border-gray-700">
        <div class="flex flex-col lg:flex-row lg:items-center justify-between">
          <div class="flex items-center">
            <div class="mr-4 bg-gradient-to-br from-green-500 to-green-600 text-white p-4 rounded-2xl shadow-sm">
              <i class="fas fa-mobile-alt text-xl"></i>
            </div>
            <div>
              <h2 class="text-2xl font-bold text-gray-900 dark:text-white"><%= device.name %></h2>
              <div class="flex items-center mt-2">
                <span class="flex items-center text-base font-medium <%= device.isConnected ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
                  <span class="flex h-3 w-3 relative mr-3">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full <%= device.isConnected ? 'bg-green-400' : 'bg-red-400' %> opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-3 w-3 <%= device.isConnected ? 'bg-green-500' : 'bg-red-500' %>"></span>
                  </span>
                  <span><%= device.isConnected ? 'Terhubung dan Siap' : 'Terputus - Perlu Scan QR' %></span>
                </span>
              </div>
            </div>
          </div>

          <% if (device.isConnected) { %>
          <button 
            class="disconnect-btn mt-4 lg:mt-0 flex items-center justify-center gap-2 px-5 py-2.5 bg-red-500 hover:bg-red-600 dark:bg-red-600 dark:hover:bg-red-700 text-white rounded-xl shadow-sm hover:shadow-md transition-all"
            data-device-id="<%= device.id %>">
            <i class="fas fa-unlink"></i>
            <span>Putuskan Koneksi</span>
          </button>
          <% } else { %>
          <button 
            class="mt-4 lg:mt-0 flex items-center justify-center gap-2 px-5 py-2.5 bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-300 rounded-xl shadow-sm hover:shadow-md transition-all">
            <i class="fas fa-qrcode"></i>
            <span>Scan QR Code</span>
          </button>
          <% } %>
        </div>
      </div>

      <!-- Device Info -->
      <div class="p-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <!-- Device Information -->
          <div class="space-y-4">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Informasi Perangkat</h3>
            
            <div class="bg-gray-50 dark:bg-gray-700/50 rounded-xl p-4 border border-gray-100 dark:border-gray-600 hover:shadow-sm transition">
              <div class="flex items-center mb-2">
                <div class="w-8 h-8 flex items-center justify-center bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-400 rounded-lg mr-3">
                  <i class="fas fa-fingerprint text-sm"></i>
                </div>
                <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Device ID</span>
              </div>
              <p class="text-sm text-gray-800 dark:text-gray-100 font-mono select-all truncate pl-11"><%= device.id %></p>
            </div>

            <div class="bg-gray-50 dark:bg-gray-700/50 rounded-xl p-4 border border-gray-100 dark:border-gray-600 hover:shadow-sm transition">
              <div class="flex items-center mb-2">
                <div class="w-8 h-8 flex items-center justify-center bg-green-100 dark:bg-green-900 text-green-600 dark:text-green-400 rounded-lg mr-3">
                  <i class="fab fa-whatsapp text-sm"></i>
                </div>
                <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Nomor WhatsApp</span>
              </div>
              <p class="text-sm text-gray-800 dark:text-gray-100 pl-11"><%= device.phone || 'Belum terhubung' %></p>
            </div>

            <div class="bg-gray-50 dark:bg-gray-700/50 rounded-xl p-4 border border-gray-100 dark:border-gray-600 hover:shadow-sm transition">
              <div class="flex items-center mb-2">
                <div class="w-8 h-8 flex items-center justify-center bg-purple-100 dark:bg-purple-900 text-purple-600 dark:text-purple-400 rounded-lg mr-3">
                  <i class="fas fa-calendar text-sm"></i>
                </div>
                <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Dibuat Pada</span>
              </div>
              <p class="text-sm text-gray-800 dark:text-gray-100 pl-11"><%= new Date().toLocaleDateString('id-ID') %></p>
            </div>
          </div>

          <!-- Token Section -->
          <div class="space-y-4">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Autentikasi & API</h3>
            
            <% if (device.token) { %>
            <div class="bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-800/20 rounded-xl p-4 border border-blue-100 dark:border-blue-700">
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Token Autentikasi</label>
              <div class="flex items-center">
                <input type="text" id="token-input"
                  class="flex-1 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 rounded-l-xl py-3 px-4 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 font-mono"
                  value="<%= device.token %>" readonly>
                <button 
                  id="copy-token-btn"
                  class="rounded-r-xl px-4 py-3 bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white flex items-center justify-center transition-all hover:shadow-md">
                  <i class="fas fa-copy"></i>
                </button>
              </div>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-3 flex items-center">
                <i class="fas fa-info-circle mr-2"></i>
                Gunakan token ini untuk autentikasi API WhatsApp
              </p>
            </div>
            <% } %>

            <!-- API Documentation -->
            <div class="bg-gray-50 dark:bg-gray-700/50 rounded-xl p-4 border border-gray-100 dark:border-gray-600">
              <h4 class="font-medium text-gray-700 dark:text-gray-300 mb-3">Dokumentasi API</h4>
              <div class="space-y-2">
                <a href="#" class="flex items-center justify-between p-2 hover:bg-white dark:hover:bg-gray-600 rounded-lg transition">
                  <span class="text-sm text-gray-600 dark:text-gray-400">API Send Message</span>
                  <i class="fas fa-external-link-alt text-gray-400"></i>
                </a>
                <a href="#" class="flex items-center justify-between p-2 hover:bg-white dark:hover:bg-gray-600 rounded-lg transition">
                  <span class="text-sm text-gray-600 dark:text-gray-400">API Get Contacts</span>
                  <i class="fas fa-external-link-alt text-gray-400"></i>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <% if (!device.isConnected) { %>
      <!-- QR Section -->
      <div class="border-t border-gray-200 dark:border-gray-700 bg-gradient-to-r from-gray-50 to-blue-50 dark:from-gray-800 dark:to-blue-900/10 p-8">
        <div class="flex flex-col lg:flex-row items-start gap-8">
          <!-- QR Code Container -->
          <div class="flex-shrink-0">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Scan QR Code</h3>
            <div class="bg-white dark:bg-gray-700 p-6 rounded-2xl shadow-lg border border-gray-200 dark:border-gray-600">
              <div id="qr-container" data-device-id="<%= device.id %>" class="w-64 h-64 flex items-center justify-center">
                <div class="text-center">
                  <div class="qr-loading mx-auto mb-4 w-12 h-12 border-4 border-blue-200 border-t-blue-600 rounded-full animate-spin"></div>
                  <p class="text-sm text-gray-600 dark:text-gray-400">Memuat QR code...</p>
                </div>
              </div>
            </div>
            <button class="w-full mt-4 flex items-center justify-center gap-2 px-4 py-3 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-600 transition">
              <i class="fas fa-redo"></i>
              <span>Refresh QR Code</span>
            </button>
          </div>
          
          <!-- Instructions -->
          <div class="flex-1">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-6">Cara Menghubungkan Perangkat</h3>
            
            <div class="space-y-4">
              <div class="flex items-start gap-4 p-4 bg-white dark:bg-gray-700 rounded-xl shadow-sm border border-gray-100 dark:border-gray-600">
                <div class="flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
                <div>
                  <h4 class="font-medium text-gray-900 dark:text-white mb-1">Buka WhatsApp di Ponsel</h4>
                  <p class="text-sm text-gray-600 dark:text-gray-400">Pastikan WhatsApp sudah terinstall dan aktif di ponsel Anda</p>
                </div>
              </div>

              <div class="flex items-start gap-4 p-4 bg-white dark:bg-gray-700 rounded-xl shadow-sm border border-gray-100 dark:border-gray-600">
                <div class="flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
                <div>
                  <h4 class="font-medium text-gray-900 dark:text-white mb-1">Akses Menu Perangkat Tertaut</h4>
                  <p class="text-sm text-gray-600 dark:text-gray-400">Masuk ke <span class="font-semibold">Setelan</span> → <span class="font-semibold">Perangkat tertaut</span> → <span class="font-semibold">Tautkan perangkat</span></p>
                </div>
              </div>

              <div class="flex items-start gap-4 p-4 bg-white dark:bg-gray-700 rounded-xl shadow-sm border border-gray-100 dark:border-gray-600">
                <div class="flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
                <div>
                  <h4 class="font-medium text-gray-900 dark:text-white mb-1">Scan QR Code</h4>
                  <p class="text-sm text-gray-600 dark:text-gray-400">Arahkan kamera ponsel Anda ke QR code di samping</p>
                </div>
              </div>
            </div>

            <!-- Info Box -->
            <div class="mt-6 p-4 bg-blue-50 dark:bg-blue-900/30 rounded-xl border border-blue-200 dark:border-blue-700">
              <div class="flex items-start">
                <i class="fas fa-info-circle text-blue-500 dark:text-blue-400 mt-1 mr-3"></i>
                <div>
                  <p class="text-sm text-blue-700 dark:text-blue-300 font-medium mb-1">Tips Penting</p>
                  <p class="text-sm text-blue-600 dark:text-blue-400">
                    Pastikan koneksi internet ponsel Anda stabil. Proses ini membutuhkan waktu beberapa detik.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <% } %>
    </div>

    <% } else { %>
    <!-- Empty State -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-12 text-center border border-gray-200 dark:border-gray-700">
      <div class="mx-auto w-32 h-32 bg-gradient-to-br from-gray-100 to-gray-200 dark:from-gray-700 dark:to-gray-600 rounded-full flex items-center justify-center mb-8 shadow-sm">
        <i class="fas fa-mobile-alt text-5xl text-gray-400 dark:text-gray-500"></i>
      </div>
      <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Belum Ada Perangkat</h3>
      <p class="text-gray-600 dark:text-gray-400 mb-8 max-w-md mx-auto leading-relaxed">
        Tambah perangkat WhatsApp pertama Anda untuk mulai mengirim dan menerima pesan secara otomatis.
      </p>
      <button class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white rounded-2xl shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-1">
        <i class="fas fa-plus"></i>
        <span class="font-semibold">Tambah Perangkat Pertama</span>
      </button>
      
      <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6 max-w-2xl mx-auto">
        <div class="text-center p-4">
          <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900 rounded-xl flex items-center justify-center mx-auto mb-3">
            <i class="fas fa-bolt text-blue-600 dark:text-blue-400"></i>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">Setup dalam 2 menit</p>
        </div>
        <div class="text-center p-4">
          <div class="w-12 h-12 bg-green-100 dark:bg-green-900 rounded-xl flex items-center justify-center mx-auto mb-3">
            <i class="fas fa-shield-alt text-green-600 dark:text-green-400"></i>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">Aman dan terenkripsi</p>
        </div>
        <div class="text-center p-4">
          <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900 rounded-xl flex items-center justify-center mx-auto mb-3">
            <i class="fas fa-infinity text-purple-600 dark:text-purple-400"></i>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">24/7 aktif</p>
        </div>
      </div>
    </div>
    <% } %>

  </div>

  <% if (device) { %>
  <script src="/js/perangkat.js"></script>
  <% } %>

  <script>
    // Theme Toggle Functionality
    const themeToggle = document.getElementById('theme-toggle');
    const themeIcon = themeToggle.querySelector('i');
    
    themeToggle.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      
      if (document.documentElement.classList.contains('dark')) {
        themeIcon.classList.remove('fa-moon');
        themeIcon.classList.add('fa-sun');
        themeIcon.classList.remove('text-gray-600');
        themeIcon.classList.add('text-yellow-400');
      } else {
        themeIcon.classList.remove('fa-sun');
        themeIcon.classList.add('fa-moon');
        themeIcon.classList.remove('text-yellow-400');
        themeIcon.classList.add('text-gray-600');
      }
    });

    // Copy Token Functionality
    const copyTokenBtn = document.getElementById('copy-token-btn');
    if (copyTokenBtn) {
      copyTokenBtn.addEventListener('click', () => {
        const tokenInput = document.getElementById('token-input');
        tokenInput.select();
        document.execCommand('copy');
        
        // Show feedback
        const originalHTML = copyTokenBtn.innerHTML;
        copyTokenBtn.innerHTML = '<i class="fas fa-check"></i>';
        copyTokenBtn.classList.remove('bg-blue-600', 'hover:bg-blue-700');
        copyTokenBtn.classList.add('bg-green-600', 'hover:bg-green-700');
        
        setTimeout(() => {
          copyTokenBtn.innerHTML = originalHTML;
          copyTokenBtn.classList.remove('bg-green-600', 'hover:bg-green-700');
          copyTokenBtn.classList.add('bg-blue-600', 'hover:bg-blue-700');
        }, 2000);
      });
    }
  </script>
</body>